#!/bin/sh
set -e

# Stage submodule pointer bumps, but only fast-forwards: a checkout that is a
# descendant of the committed gitlink is staged automatically; anything behind
# or sideways is left alone and must be staged explicitly with `git add`.
# (A blind `git add` here once reverted the deliberate apps/electron rxdb-17.4
# pin — see PR #772.)
node ./scripts/stage-submodule-bumps.mjs

# Block docs/ files from being committed
docs_files=$(git diff --cached --name-only --diff-filter=ACM | grep '^docs/' || true)
if [ -n "$docs_files" ]; then
  echo "BLOCKED: docs/ files should not be committed to the public repo:"
  echo "$docs_files"
  echo ""
  echo "Remove them from staging with:"
  echo "  git reset HEAD -- docs/"
  exit 1
fi

# Run lint-staged to auto-fix formatting on staged files
pnpm exec lint-staged
