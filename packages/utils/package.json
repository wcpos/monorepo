{
  "name": "@wcpos/utils",
  "version": "1.9.1",
  "description": "Shared utils for WooCommerce POS",
  "author": "kilbot <paul@kilbot.com>",
  "homepage": "https://github.com/wcpos/utils#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/wcpos/utils.git"
  },
  "license": "MIT",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app-info": {
      "browser": "./src/app-info/index.web.ts",
      "default": "./src/app-info/index.ts"
    },
    "./logger": "./src/logger/index.ts",
    "./logger/constants": "./src/logger/constants.ts",
    "./logger/error-codes": "./src/logger/error-codes.ts",
    "./open-external-url": {
      "browser": "./src/open-external-url.web.ts",
      "default": "./src/open-external-url.ts"
    },
    "./platform": {
      "browser": "./src/platform/index.web.ts",
      "default": "./src/platform/index.ts"
    },
    "./*": "./src/*"
  },
  "files": [
    "src/**"
  ],
  "scripts": {
    "test": "jest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "expo-constants": "~56.0.14",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo-constants": {
      "optional": true
    }
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "react-native-logs": "^5.6.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.10"
  }
}
