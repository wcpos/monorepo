{
	"name": "@wcpos/query",
	"version": "1.7.3",
	"description": "Query and Replication for WooCommerce POS",
	"author": "kilbot <paul@kilbot.com>",
	"license": "MIT",
	"main": "src/index.ts",
	"type": "module",
	"files": [
		"src/*"
	],
	"scripts": {
		"clean": "shx rm -rf dist && rm -rf node_modules",
		"test": "NODE_OPTIONS=--experimental-vm-modules pnpm exec jest",
		"lint": "eslint src --ext .js,.jsx,.ts,.tsx",
		"lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
		"typecheck": "bash -c '! tsc --noEmit 2>&1 | grep -q \"^src/.*error TS\"'"
	},
	"dependencies": {
		"lodash": "^4.18.1",
		"observable-hooks": "^4.2.4",
		"rxdb": "17.2.0",
		"rxjs": "7.8.2",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.0",
		"@types/jest": "^30.0.0",
		"@types/lodash": "^4.17.20",
		"jest": "^30.1.0",
		"jest-environment-jsdom": "^30.4.1",
		"rxjs-marbles": "^7.0.1",
		"ts-jest": "^29.4.6"
	}
}
