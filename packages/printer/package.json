{
	"name": "@wcpos/printer",
	"version": "1.9.1",
	"description": "Printer encoding and transport for WooCommerce POS",
	"author": "kilbot <paul@kilbot.com>",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./encoder": "./src/encoder/index.ts",
		"./encoder/render-preview": "./src/encoder/render-preview.ts",
		"./ipc-channels": "./src/ipc/channels.cts",
		"./transport/device-key": "./src/transport/device-key.ts"
	},
