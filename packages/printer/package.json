		"@point-of-sale/webbluetooth-receipt-printer": "2.0.0",
		"@point-of-sale/webusb-receipt-printer": "2.0.0",
		"@wcpos/receipt-renderer": "workspace:*",
		"p-queue": "^9.3.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"jsdom": "^26.1.0",
		"react-dom": "19.2.7",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"expo-print": ">=55.0.0",
		"react-native-esc-pos-printer": ">=4.0.0",
		"react-native-star-io10": ">=1.0.0",
		"react-native-tcp-socket": ">=6.0.0"
	},
	"peerDependenciesMeta": {
		"expo-print": {
			"optional": true
		},
		"react-native-tcp-socket": {
			"optional": true
		},
		"react-native-esc-pos-printer": {
			"optional": true
		},
		"react-native-star-io10": {
			"optional": true
		}
	}
