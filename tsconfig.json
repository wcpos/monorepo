{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"module": "esnext",
		"rootDir": ".",
		"typeRoots": ["./types", "./node_modules/@types"],
		"types": ["jest", "node", "wcpos-dependabot-shims"],
		"paths": {
			"@wcpos/main/*": ["apps/main/*"],
			"@wcpos/electron/*": ["apps/electron/*"],
			"@wcpos/components/*": ["packages/components/src/*"],
			"@wcpos/core/*": ["packages/core/src/*"],
			"@wcpos/database": ["packages/database/src/index"],
			"@wcpos/database/*": ["packages/database/src/*"],
			"@wcpos/hooks/*": ["packages/hooks/src/*"],
			"@wcpos/receipt-renderer": ["packages/receipt-renderer/src/index"],
			"@wcpos/receipt-renderer/*": ["packages/receipt-renderer/src/*"],
			"@wcpos/printer": ["packages/printer/src/index"],
			"@wcpos/printer/*": ["packages/printer/src/*"],
			"@wcpos/query": ["packages/query/src/index"],
			"@wcpos/query/*": ["packages/query/src/*"],
			"@wcpos/utils/*": ["packages/utils/src/*"],
		}
	},
	"include": ["**/*.ts", "**/*.tsx"]
}
