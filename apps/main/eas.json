{
  "cli": {
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "monorepo": {
      "pnpm": "11.1.1",
      "cache": {
        "key": "turbo",
        "paths": [
          "../../.turbo/cache"
        ]
      },
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true"
      },
      "node": "22.13.1"
    },
    "development": {
      "extends": "monorepo",
      "distribution": "internal",
      "developmentClient": true,
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "extends": "monorepo",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true
    },
    "adhoc": {
      "extends": "monorepo",
      "distribution": "internal"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "beta",
        "changesNotSentForReview": true,
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "paul@kilbot.com.au",
        "ascAppId": "6742204061",
        "appleTeamId": "G7L8G4KJ7A",
        "metadataPath": "./store-metadata/ios"
      }
    }
  }
}
