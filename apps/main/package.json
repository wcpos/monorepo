    "@shopify/react-native-skia": "2.4.18",
    "@tailwindcss/postcss": "^4.1.17",
    "expo": "~55.0.19",
    "expo-auth-session": "~55.0.15",
    "expo-blob": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "~55.0.30",
