    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.8",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "~55.0.10",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.9",
    "js-base64": "^3.7.7",
    "observable-hooks": "4.2.4",
    "postcss": "^8.5.10",
    "react": "~19.2.5",
    "react-dom": "~19.2.5",
    "react-native": "0.83.6",
