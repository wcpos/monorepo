{
  "name": "@wcpos/main",
  "main": "expo-router/entry",
  "version": "1.9.1",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "build": "expo export --output-dir ./build --platform all",
    "build:web": "expo export --output-dir ./web-build --platform=web",
    "build:electron": "ELECTRON=true expo export --output-dir ./electron-build --platform=web",
    "eas-build-pre-install": "[ \"$EAS_BUILD_PLATFORM\" = \"android\" ] && sudo apt-get update && sudo apt-get install -y libsecret-1-dev || true",
    "eas-build-post-install": "pnpm run -w build:main",
    "lint": "eslint app components --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint app components --ext .js,.jsx,.ts,.tsx --fix"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "expo": {
    "install": {
      "exclude": ["jest"]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": ["react-native-star-io10", "react-native-tcp-socket"]
      }
    }
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-community/netinfo": "12.0.1",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@wcpos/components": "workspace:*",
    "@wcpos/core": "workspace:*",
    "@wcpos/database": "workspace:*",
    "@wcpos/hooks": "workspace:*",
    "@wcpos/printer": "workspace:*",
    "@wcpos/query": "workspace:*",
    "@wcpos/utils": "workspace:*",
    "expo": "~56.0.5",
    "expo-auth-session": "~56.0.12",
    "expo-blob": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.16",
    "expo-file-system": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.12",
    "expo-localization": "~56.0.6",
    "expo-print": "~56.0.3",
    "expo-router": "~56.2.7",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "js-base64": "^3.7.8",
    "observable-hooks": "4.2.4",
    "postcss": "^8.5.15",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-device-info": "^15.0.2",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-esc-pos-printer": "4.5.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-star-io10": "^1.12.1",
    "react-native-svg": "15.15.4",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "~13.16.1",
    "react-native-worklets": "~0.8.3",
    "tailwindcss": "^4.3.0",
    "uniwind": "npm:uniwind-pro@1.2.0",
    "victory-native": "^41.20.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "dotenv": "^17.4.2",
    "expo-atlas": "^0.4.3",
    "jest": "^30.4.2",
    "jest-expo": "~56.0.4",
    "react-native-nitro-modules": "0.35.7",
    "tw-animate-css": "^1.4.0"
  },
  "private": true
}
