n></span>\n\t\t\t<span style=\"white-space: nowrap; margin-left: 12px;\">$999.99</span>\n\t\t</div>\n\t\t<div style=\"display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; font-size: 13px;\">\n\t\t\t<span>Another product with a very long translated title <span style=\"color: #999; font-size: 12px;\">× 1</span></span>\n\t\t\t<span style=\"white-space: nowrap; margin-left: 12px;\">$999.99</span>\n\t\t</div>\n\t</div>\n\n\t<!-- Divider -->\n\t<div style=\"border-top: 1px solid #e2e2e2; margin: 20px 0;\"></div>\n\n\t<!-- Totals Section -->\n\t<div style=\"background: #f8f8f8; border-radius: 6px; padding: 14px 16px; margin-bottom: 20px;\">\n\n\n\n\n\t\t<div style=\"display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;\">\n\t\t\t<span style=\"color: #555;\">Subtotal</span>\n\t\t\t<span>$1818.16</span>\n\t\t</div>\n\n\t\t<div style=\"display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;\">\n\t\t\t<span style=\"color: #555;\">VAT (10%)</span>\n\t\t\t<span>$181.82</span>\n\t\t</div>\n\n\t\t<!-- Grand Total -->\n\t\t<div style=\"display: flex; justify-content: space-between; align-items: baseline; font-weight: 700; font-size: 18px; padding-top: 10px; border-top: 2px solid #333; margin-top: 10px;\">\n\t\t\t<span>Total</span>\n\t\t\t<span>$1999.98</span>\n\t\t</div>\n\t</div>\n\n\t<!-- Divider -->\n\t<div style=\"border-top: 1px solid #e2e2e2; margin: 20px 0;\"></div>\n\n\t<!-- Payments -->\n\t<div style=\"margin-bottom: 20px;\">\n\t\t<div style=\"display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;\">\n\t\t\t<span style=\"color: #555;\">Split tender</span>\n\t\t\t<span>$1999.98</span>\n\t\t</div>\n\t</div>\n\n\t<!-- Footer -->\n\t<div style=\"text-align: center; margin-top: 24px; font-size: 13px; color: #999;\">\n\t\tThank you, Grace Hopper!\n\t</div>\n\n</div>\n"
