{
	"name": "@wcpos/monorepo",
	"version": "1.0.0",
	"description": "A POS built for WooCommerce.",
	"private": true,
	"scripts": {
		"build": "turbo build --filter='{./packages/*}' --filter='{./apps/main}'",
		"typecheck": "turbo typecheck --filter='{./packages/*}' --filter='{./apps/main}'",
		"lint": "turbo lint --filter='{./packages/*}' --filter='{./apps/main}'",
		"test": "turbo test --filter='{./packages/*}'",
		"fix": "turbo fix --filter='{./packages/*}' --filter='{./apps/main}'",
		"dev": "pnpm --dir apps/main dev",
		"main": "pnpm --filter @wcpos/main",
		"template-studio": "pnpm --filter @wcpos/template-studio",
		"electron": "pnpm --dir apps/electron",
		"web": "pnpm --dir apps/web",
		"components": "pnpm --filter @wcpos/components",
		"core": "pnpm --filter @wcpos/core",
		"database": "pnpm --filter @wcpos/database",
		"hooks": "pnpm --filter @wcpos/hooks",
		"printer": "pnpm --filter @wcpos/printer",
		"query": "pnpm --filter @wcpos/query",
		"receipt-renderer": "pnpm --filter @wcpos/receipt-renderer",
		"utils": "pnpm --filter @wcpos/utils",
		"prepare": "husky"
	},
	"lint-staged": {
		"!(*.worker).{js,jsx,ts,tsx}": "eslint --fix"
	},
	"devDependencies": {
		"bonjour-service": "^1.3.0",
		"eslint": "^9.39.4",
		"expo": "~56.0.3",
		"glob": "^13.0.6",
		"lint-staged": "^16.4.0",
		"prettier-plugin-tailwindcss": "^0.8.0"
	},
	"dependencies": {
		"turbo": "^2.9.14",
		"typescript": "^5.9.3"
	}
}
