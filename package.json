{
  "private": true,
  "name": "@wcpos/monorepo",
  "scripts": {
    "dev": "turbo dev",
    "dev:main": "turbo dev --filter=\"{./apps/main}...\"",
    "dev:electron": "turbo dev --filter=\"{./apps/electron}...\"",
    "build": "turbo build",
    "build:main": "turbo build --filter=\"...{./apps/main}\"",
    "test": "turbo run test --filter='{./packages/*}' --filter='{./apps/main}'",
    "test:ci": "pnpm jest --ci --passWithNoTests && cd packages/query && npx jest --config jest.config.cjs --ci",
    "lint": "turbo lint --continue --concurrency=1 --filter='{./packages/*}' --filter='{./apps/main}'",
    "lint:fix": "turbo lint:fix --continue --concurrency=1 --filter='{./packages/*}' --filter='{./apps/main}'",
    "typecheck": "turbo typecheck --filter='{./packages/*}' --filter='{./apps/main}'",
    "main:expo": "pnpm --filter @wcpos/main exec expo",
    "clean": "node scripts/clean-node-modules",
    "electron": "pnpm --filter @wcpos/app-electron",
    "main": "pnpm --filter @wcpos/main",
    "web": "pnpm --filter @wcpos/web-bundle",
    "components": "pnpm --filter @wcpos/components",
    "core": "pnpm --filter @wcpos/core",
    "database": "pnpm --filter @wcpos/database",
    "eslint": "pnpm --filter @wcpos/eslint-config",
    "hooks": "pnpm --filter @wcpos/hooks",
    "query": "pnpm --filter @wcpos/query",
    "utils": "pnpm --filter @wcpos/utils",
    "preinstall": "pnpm ignored-builds || true; git rev-parse --is-inside-work-tree >/dev/null 2>&1 && rm -f \"$(git rev-parse --git-path wcpos-submodule-updated)\" && git submodule update --init --remote && touch \"$(git rev-parse --git-path wcpos-submodule-updated)\" || true",
    "expo:install": "pnpm --filter main exec expo install",
    "extract:translations": "node scripts/extract-js-strings.js",
    "postinstall": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && test -f \"$(git rev-parse --git-path wcpos-submodule-updated)\" && git add apps/electron apps/web && rm -f \"$(git rev-parse --git-path wcpos-submodule-updated)\" || true",
    "prepare": "git config core.hooksPath .githooks"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "overrides": {
      "expo": "~55.0.0",
      "lightningcss": "1.30.1",
      "uniwind": "npm:uniwind-pro@latest",
      "react": "~19.2.0",
      "react-dom": "~19.2.0",
      "react-native": "~0.83.2",
      "react-native-edge-to-edge": "^1.6.2",
      "react-native-gesture-handler": "~2.30.0",
      "react-native-safe-area-context": "~5.6.2",
      "@react-navigation/drawer": "^7.5.0",
      "tar": "^7.5.11"
    },
    "packageExtensions": {
      "rxdb-premium-old@16.21.1": {
        "dependencies": {
          "rxdb": "16.21.1"
        }
      },
      "rxdb-premium@16.21.1": {
        "dependencies": {
          "rxdb": "16.21.1"
        }
      }
    },
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia",
      "@tailwindcss/oxide",
      "@zowe/secrets-for-zowe-sdk",
      "better-sqlite3",
      "core-js",
      "electron",
      "esbuild",
      "fs-xattr",
      "keccak",
      "macos-alias",
      "protobufjs",
      "react-native-esc-pos-printer",
      "rxdb",
      "rxdb-premium",
      "secp256k1",
      "uniwind-pro",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@firebase/util",
      "electron-winstaller"
    ],
    "patchedDependencies": {
      "react-native-esc-pos-printer@4.5.0": "patches/react-native-esc-pos-printer@4.5.0.patch"
    }
  },
  "lint-staged": {
    "!(*.worker).{js,jsx,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "glob": "^13.0.0",
    "lint-staged": "^16.3.2"
  },
  "dependencies": {
    "turbo": "^2.8.14",
    "typescript": "^5.8.3"
  }
}
