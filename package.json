{
  "private": true,
  "name": "@wcpos/monorepo",
  "scripts": {
    "start": "node scripts/start-dev.mjs",
    "dev": "turbo dev",
    "dev:main": "turbo dev --filter=\"{./apps/main}...\"",
    "dev:electron": "turbo dev --filter=\"{./apps/electron}...\"",
    "build": "turbo build",
    "build:main": "turbo build --filter=\"...{./apps/main}\"",
    "test": "turbo run test --filter='{./packages/*}' --filter='{./apps/main}'",
    "test:ci": "pnpm jest --ci --passWithNoTests && cd packages/query && npx jest --config jest.config.cjs --ci",
    "test:scripts": "node scripts/check-dep-duplicates.mjs && node scripts/check-expo-alignment.mjs && node --test scripts/*.test.mjs && pnpm --filter @wcpos/virtual-printer test",
    "lint": "turbo lint --continue --concurrency=1 --filter='{./packages/*}' --filter='{./apps/main}'",
    "lint:fix": "turbo lint:fix --continue --concurrency=1 --filter='{./packages/*}' --filter='{./apps/main}'",
    "typecheck": "turbo typecheck --filter='{./packages/*}' --filter='{./apps/main}'",
    "main:expo": "pnpm --filter @wcpos/main exec expo",
    "clean": "node scripts/clean-node-modules",
    "electron": "pnpm --filter @wcpos/app-electron",
    "main": "pnpm --filter @wcpos/main",
    "web": "pnpm --filter @wcpos/web-bundle",
    "components": "pnpm --filter @wcpos/components",
    "core": "pnpm --filter @wcpos/core",
    "database": "pnpm --filter @wcpos/database",
    "eslint": "pnpm --filter @wcpos/eslint-config",
    "hooks": "pnpm --filter @wcpos/hooks",
    "query": "pnpm --filter @wcpos/query",
    "utils": "pnpm --filter @wcpos/utils",
    "preinstall": "pnpm ignored-builds || true; git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git submodule update --init || true",
    "expo:install": "pnpm --filter main exec expo install",
    "extract:translations": "node scripts/extract-js-strings.js",
    "translations:check": "node scripts/extract-js-strings.js --check",
    "prepare": "git config core.hooksPath .githooks",
    "virtual-printer": "pnpm --filter @wcpos/virtual-printer start",
    "submodules:update": "git submodule update --init --remote .wiki apps/electron apps/web && git add .wiki apps/electron apps/web"
  },
  "packageManager": "pnpm@11.1.1",
  "lint-staged": {
    "!(*.worker).{js,jsx,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "expo": "~56.0.11",
    "glob": "^13.0.6",
    "lint-staged": "^16.4.0",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "dependencies": {
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
